{
  "expo": {
    "name": "Primansh Agency OS",
    "slug": "primansh-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "primansh-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070b14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.primansh.agencyos"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070b14"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.primansh.agencyos"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dd80daac-2f57-43ad-9df2-96bcaad8cad0"
      }
    },
    "owner": "arpan-sadhu"
  }
}
